# Variáveis de produção (copie para o painel do Railway → Variables).
# NÃO comite valores reais — este arquivo é só um modelo.

# Perfil que ativa o PostgreSQL (já é o default da imagem Docker)
SPRING_PROFILES_ACTIVE=postgres

# Banco PostgreSQL.
# No Railway, o plugin Postgres expõe DATABASE_URL no formato
#   postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
# Converta para JDBC e separe usuário/senha:
DB_URL=jdbc:postgresql://HOST:PORTA/BANCO
DB_USER=postgres
DB_PASSWORD=troque-aqui

# Segurança (Fase 7) — OBRIGATÓRIO em produção
ASUS_SECURITY_ENFORCE=true
# Gere algo aleatório com >= 32 bytes (ver DEPLOY.md)
ASUS_JWT_SECRET=troque-por-um-segredo-aleatorio-de-no-minimo-32-bytes
# Mesma URL pública do app (single-service); aceita lista separada por vírgula
ASUS_CORS_ORIGINS=https://SEU-APP.up.railway.app

# (Opcional) diretório de uploads — aponte para um Volume persistente do Railway
# ASUS_UPLOADS_DIR=/app/uploads

# (Opcional) a porta é injetada automaticamente pelo Railway via PORT
# PORT=8080
