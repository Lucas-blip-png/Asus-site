# Variáveis de produção (copie para o painel do Railway → Variables).
# NÃO comite valores reais — este arquivo é só um modelo.

# Perfil que ativa o PostgreSQL (já é o default da imagem Docker)
SPRING_PROFILES_ACTIVE=postgres

# Banco PostgreSQL.
# No Railway, o plugin Postgres expõe DATABASE_URL no formato
#   postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
# Converta para JDBC e separe usuário/senha:
DB_URL=jdbc:postgresql://HOST:PORTA/BANCO
DB_USER=postgres
DB_PASSWORD=troque-aqui

# Segurança (Fase 7) — OBRIGATÓRIO em produção
ASUS_SECURITY_ENFORCE=true
# Gere algo aleatório com >= 32 bytes (ver DEPLOY.md)
ASUS_JWT_SECRET=troque-por-um-segredo-aleatorio-de-no-minimo-32-bytes
# Mesma URL pública do app (single-service); aceita lista separada por vírgula
ASUS_CORS_ORIGINS=https://SEU-APP.up.railway.app

# Conta de dono/admin (criada/garantida no boot, dona da organização padrão).
# A SENHA fica só aqui (env), NUNCA no código.
ASUS_ADMIN_EMAIL=voce@exemplo.com
ASUS_ADMIN_SENHA=troque-por-uma-senha-forte
ASUS_ADMIN_NOME=Seu Nome

# (Opcional) diretório de uploads — aponte para um Volume persistente do Railway
# ASUS_UPLOADS_DIR=/app/uploads

# (Opcional) a porta é injetada automaticamente pelo Railway via PORT
# PORT=8080

# ============================================================
# (Opcional) Integrações externas — só plugar credenciais.
# Passo a passo e código drop-in em INTEGRACOES.md.
# ============================================================

# --- Storage em nuvem (S3 / Cloudflare R2 / GCS) ---
# ASUS_STORAGE_TIPO=s3
# ASUS_S3_BUCKET=meu-bucket
# ASUS_S3_REGION=auto
# ASUS_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com   # AWS S3: deixe vazio
# ASUS_S3_ACCESS_KEY=
# ASUS_S3_SECRET_KEY=
# ASUS_S3_PUBLIC_BASE_URL=https://cdn.seu-dominio.com

# --- Gateway de pagamento (Stripe ou Mercado Pago) ---
# ASUS_PAYMENTS_PROVIDER=stripe
# ASUS_PAYMENTS_SUCCESS_URL=https://SEU-APP/conta?pago=1
# ASUS_PAYMENTS_CANCEL_URL=https://SEU-APP/conta?cancelado=1
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# --- Login social Google (OAuth2) ---
# ASUS_OAUTH_GOOGLE_ENABLED=true
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...
